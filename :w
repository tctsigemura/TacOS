/* 与えた曲を内容として持つプレイリストを作成する
 *  - プレイリストの命名規則は、/Playlists/pli.txt
 *  - 与える曲のリストには最後にnullを必ず挿入する
 */
public void create_playlist(song[] songs) {
    dbgPutStr("create_playlist() call OK\n");
    filepath = "";
    for (int i=0; i<5; i=i+1) {
        int fd;
        boolean isCreate = false;

        filepath = files[i];
        dbgPutStr(filepath); dbgPutStr("\n");
        filepath = pltCat(filepath);
        dbgPutStr("file path: "); dbgPutStr(filepath); dbgPutStr("\n");
        fd = open(filepath,O_APPEND);

        // ファイルが非存在
        if(fd < 0){
            dbgPutStr("file is not found OK\n");
            isCreate = true;
            creat(filepath);

            int j = 0;
            while (true) { 
                if (songs[j] != null) {
                    write(fd, songs[j].name, strLen(songs[j].name));
                    write(fd, "\n", 1);
                } else {
                    break;
                }
                j = j + 1;
            }
            break;
        }
        close(fd);
    }
}


/* 与えた名前のプレイリストに与えた曲を挿入する
 *   - 曲数は最大で10曲
 *   - 与える曲のリストには最後にnullを必ず挿入する
 */
public void add_songs(char[] pltname, song[] songs){
    char[] filepath = "               ";
    writeText = "";
    int fd;
    filepath = pltCat(pltname);

    fd = open(filepath, O_APPEND);
    dbgPutStr("file open\n");
    if (fd >= 0) {
        int i = 0;
        while (true) {
            if (songs[i] != null) {
                writeText = strCat(writeText, songs[i].name);
                writeText = strCat(writeText, "\n");
            }
            else {
                break;
            }
        }
        write(fd, writeText, strLen(writeText));
    }
    close(fd);
}



// ----------------------------------------------------------------------
// 内部関数
// ----------------------------------------------------------------------
//
char[][] sortWords(char[][] words, int n) {
    for (int i = 0; i < n-1; i = i+1) {
        if (strLen(words[i]) == 0 || words[i][0] == ' ') continue;
        for (int j = i+1; j < n; j = j+1) {
            if (strLen(words[j]) == 0 || words[j][0] == ' ') continue;
            if (strCmp(words[i], words[j]) > 0) {
                char[] tmp = "          ";
                strCpy(tmp, words[i]);
                strCpy(words[i], words[j]);
                strCpy(words[j], tmp);
            }
        }
    }
    return words;
}

// ソング配列の初期化を行う
void init_songs() {
    for (int i=0; i<50; i=i+1) {
        songs[i].index = -1;
        songs[i].fav = false;
        strCpy(songs[i].artist, "");
        strCpy(songs[i].name, "");
    }
}

// アルバム配列の初期化を行う
void init_albums() {
    for (int i=0; i<5; i=i+1) { 
        albums[i].num = -1;
        strCpy(albums[i].name, "");
    }
}

// プレイリスト配列の初期化を行う
void init_playlists() {
    for (int i=0; i<5; i=i+1) { 
        playlists[i].num = -1;
        strCpy(playlists[i].name, "");
    }
}

// いいね配列の初期化を行う
void init_favs() {
    for (int i=0; i<50; i=i+1) {
        strCpy(fav_paths[i], "");
        is_favs[i] = false;
    }
}

// ファイルから読み込んだプレイリストの曲数を取得する
int lenSongofPlt(char[] pltname) {
    int fd;
    int file_num = 0;

    fd = open(pltname, READ_MODE);

    if (fd >= 0) {
        read(fd, context, 2048);

        int i = 0;
        while (context[i] != '\0') {
            if (context[i] == '\n') {
                file_num = file_num + 1;
            }
        
            i = i + 1;
        }
    }

    close(fd);

    return file_num;
}


Mp3Tag getMp3Tag(char[] file_path) {
    Stat st;

    stat(file_path, st);
    file_size[0] = st.lenH; file_size[1] = st.lenL;

    tag_pos = _sub32(file_size, file_dis);

    int fd = open(file_path, READ_MODE);
    if (fd >= 0) {
        if (seek(fd, tag_pos[0], tag_pos[1]) == 0) {
            read(fd, buf, 3);
            read(fd, buf, 30);
            for (int i=0; i<30; i=i+1) {
                tag.song_name[i] = buf[i];
            }
            read(fd, buf, 30);
            for (int i=0; i<30; i=i+1) {
                tag.artist_name[i] = buf[i];
            }
        }
    }
    close(fd);

    return tag;
}

void attach_attr_song(song s, char[] path) {
    Mp3Tag t = getMp3Tag(path);
                              
    s.index = i;
    strCpy(s.artist, t.artis_name);
    strCpy(s.path, path);
    strCpy(s.name, t.song_name);
}



// ----------------------------------------------------------------------
// グローバル関数
// ----------------------------------------------------------------------
public song[] fetch_songs(char[] name, char[] sort) {
    init_songs();

    // --- song構造体配列を取ってくる ---
    // プレイリストだった場合 
    if (strCmp(name, "pl0") == 0) {}
    else if (strCmp(name, "pl1") == 0) {}
    else if (strCmp(name, "pl2") == 0) {}
    else if (strCmp(name, "pl3") == 0) {}
    else if (strCmp(name, "pl4") == 0) {}
    else if (strCmp(name, "history") == 0) {}
    else if (strCmp(name, "fav") == 0) {}
    else if (strCmp(name, "All") == 0) {
        albums = fetch_albums();

        strCpy(file_path, ALBUM_PATH); strCat(file_path, albums.name); strCat(file_path, "/");


    }
    // アルバムを取ってくる
    else {
        strCpy(file_path, ALBUM_PATH); strCat(file_path, name); strCat(file_path, "/");

        int fd = open(file_path, READ_MODE);

        int i = 0;
        while (true) {
            dir = readDir(fd, "MP3");

            if (dir == null) break;

            strCpy(buf, file_path); strCat(buf, dir.name);

            attach_attr_song(song[i], buf);
        
            i = i + 1;
        }
    }

    // --- ここからソート ---

    return songs;
}

public album[] fetch_albums() {
    init_albums();

    int fd = open(ALBUM_PATH, READ_MODE);

    if (fd >= 0) {
        int i = 0;
        while (true) {
            dir = readDir(fd, null);

            if (dir == null) break;

            strCpy(albums[i].name, dir.name);
            strCpy(file_path, ALBUM_PATH); strCat(file_path, dir.name); strCat(file_path, "/");

            int album_fd = open(file_path, READ_MODE);
            int file_num = 0;
            while (true) {
                dir = readDir(album_fd, "MP3");

                if (dir == null) break;

                file_num = file_num + 1;
            }

            albums[i].num = file_num;
            close(album_fd);

            i = i + 1;
        }
    }

    close(fd);

    return albums;
}

public playlist[] fetch_playlists() {
    init_playlists();

    int fd;

    int j = 0;
    for (int i=0; i<10; i=i+1) {
        strCpy(file_path, PLAYLIST_PATH); strCat(file_path, playlist_names[i]); strCat(file_path, ".txt");
        fd = open(file_path, READ_MODE);

        if (fd < 0) {
            close(fd);
            continue;
        }

        close(fd);

        strCpy(playlists[j].name, playlist_names[i]);
        playlists[j].num = lenSongofPlt(file_path);

        j = j + 1;


    }

    return playlists;
}


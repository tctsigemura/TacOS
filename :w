public void remove_song(char[] pltname, song[] songs){ //消したい曲のファイル指定と消したい曲を指定
    char[] filepath;
    int fd;
    char[] buffer = malloc(1024);
    char[] new_content = malloc(1024);
    int bytes_read;
    
    filepath = pltCat(pltname);

    fd = open(filepath, 0);
    if (fd < 0) {
        dbgPutStr("can not open");    
        return;
    }
    seek(fd, 0, 0);

    bytes_read = read(fd, buffer, 1023);
    close(fd);
    if (bytes_read <= 0) {
        return;
    }
    buffer[bytes_read] = '\0';

    new_content[0] = '\0';
    
    int current_pos = 0;
    while(current_pos < bytes_read) {
        char[] line = "";
        int line_len = 0;
        while(current_pos < bytes_read && buffer[current_pos] != '\n') {
            line[line_len] = buffer[current_pos];
            line_len = line_len + 1;
            current_pos = current_pos + 1;
        }
        current_pos = current_pos + 1; 
        line[line_len] = '\0';
        dbgPutStr("\n");
        dbgPutStr(line);
        dbgPutStr("\n");
        dbgPutStr(filepath);
        dbgPutStr("\n");
        if(strCmp(line, filepath) != 0) {
            strCat(new_content, line);
            strCat(new_content, "\n");
        }
    }

    fd = open(filepath, 1);
    if (fd < 0) {
        return;
    }
    write(fd, new_content, strLen(new_content));
    close(fd);
}



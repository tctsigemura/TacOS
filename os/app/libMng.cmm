char[] pltCat(char[] word){
    char[] filepath = "              ";
    strCpy(filepath, "/Album/");
    strCat(filepath, word);
    strCat(filepath, ".txt");
    return filepath;
}

char[] pltCatPl(char[] word){
    char[] filepath = "              ";
    strCpy(filepath, "/Playlist/");
    strCat(filepath, word);
    strCat(filepath, ".txt");
    return filepath;
}


void create_album(char[] paths) {
    char[] filepath;
    int i = 0;
    int fd;
    filepath = pltCat(paths);
    // strCpy(filepath, "/Playlist/");
    // strCat(filepath, paths);
    // strCat(filepath, ".txt");
    fd = open(filepath,0);
    if(fd < 0){
        creat(filepath);
    }
    close(fd);

}

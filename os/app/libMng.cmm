char[][] sortWords(char[][] words, int n) {
    for (int i = 0; i < n-1; i = i+1) {
        if (strLen(words[i]) == 0 || words[i][0] == ' ') continue;
        for (int j = i+1; j < n; j = j+1) {
            if (strLen(words[j]) == 0 || words[j][0] == ' ') continue;
            if (strCmp(words[i], words[j]) > 0) {
                char[] tmp = "          ";
                strCpy(tmp, words[i]);
                strCpy(words[i], words[j]);
                strCpy(words[j], tmp);
            }
        }
    }
    return words;
}

char[][] album_name = {"al1","al2","al3","al4","al5"};
char[][] playlist_name = {"pl1","pl2","pl3","pl4","pl5"};
char[] pltCat(char[] word){
    char[] filepath = "              ";
    strCpy(filepath, "/Album/");
    strCat(filepath, word);
    strCat(filepath, ".txt");
    return filepath;
}

char[] pltCatPl(char[] word){
    char[] filepath = "              ";
    strCpy(filepath, "/Playlist/");
    strCat(filepath, word);
    strCat(filepath, ".txt");
    return filepath;
}


void create_album(char[] paths) {
    char[] filepath;
    int i = 0;
    int fd;
    filepath = pltCat(paths);
    fd = open(filepath,0);
    if(fd < 0){
        creat(filepath);
    }
    close(fd);

}

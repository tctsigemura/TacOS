//
// --- 構造体 ---
//
#ifndef STRUCTURES_H
#define STRUCTURES_H

struct typeSt {
    char[] type;
};

struct modeSt {
    char[] type;
    int id;
    char[] name;
};

struct album {
    char[] type;
    int num;
    char[] name;
};

struct song {
    char[] type;
    int index;
    char[] name;
    boolean fav;
    char[] artist;
    char[] path;
};

struct playlist {
    char[] type;
    int num;
    char[] name;
};

struct Mp3Tag {
    char[] song_name;
    char[] artist_name;
};

struct SelectedItem {
    char[] type;
    int idx;
    void[] item;
};

struct SelectingItem {
    char[] type;
    char[] name;
    boolean[] is_selecting;
};

struct DisplaySongInfo {
    song playingsong;
    int totalsongs;
    int idx;
    boolean is_normal;
    boolean is_loop;
    boolean is_repeat;
    boolean is_shuffle;
    int playstatus;
    boolean is_paused;
};

struct I_ScrnSt {
    int mode;
    int sw;
    char[][] scrndata;
    int volume;
};

struct O_ScrnSt {
    char[] type;
    void[] item;
};

struct I_StrmSt {
    int sw;
};

struct O_StrmSt {
    song crt_song;
    song[] history;
    int type;
    char[] super_name;
};

struct I_LibSt {
    char[] type;
    char[] name;
    char[] sort;
};

struct O_LibSt {
    char[] type;
    void[] item;
};

struct I_StgSt {
    int sw;
};

struct I_PlistSt {
    char[] pltname;
    song[] songs;
};

struct O_PlistSt {
    playlist plt;
};

#endif

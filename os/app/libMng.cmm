// /MP3/HOGE/hoge.mp3
// ↑とヒットするような/FAV.TXTを取得し、path, t/fでやればいい
// /FAV.TXTが存在しなければ作る。path, t/fがなければ新しく作成する。
public void fav_song(song s) {
    printF("called fav_song()\n");

    init_favs();

    int fd;

    // 存在していないなら作る
    fd = open(FAV_PATH, READ_MODE);

    if (fd < 0) {
        creat("FAV_PATH");
    }

    close(fd);

    // 現在のfav情報を読み込む
    fd = open(FAV_PATH, READ_MODE);

    if (fd >= 0) {
        read(fd, context, 2048);

        int i = 0; int j = 0; int k = 0;
        while (context[i] != '\0') {
            if (context[i] == '\n') {
                j = j + 1;
                k = 0;
            } else if (context[i] == ',') {
                if (context[i + 1] == 't')
                    is_favs[j] = true;
                i = i + 1;
            } else {
                fav_paths[j][k] = context[i];
                k = k + 1;
            }

            printF("%c",fav_paths[j][k]);
            i = i + 1;
        }
    }

    close(fd);

    // favファイルの初期化
    remove(FAV_PATH);
    creat(FAV_PATH);
    
    // fav情報を新たに書き込み
    fd = open(FAV_PATH, WRITE_MODE);

    int i = 0;
    boolean is_fav = false;
    while (strCmp(fav_paths[i], "") != 0) {
        write(fd, fav_paths[i], strLen(fav_paths[i]));
        write(fd, ",", 1);

        if (strCmp(fav_paths[i], s.path) == 0) {
            is_fav = true;
            if (s.fav) write(fd, "t\n", 2);
            else write(fd, "f\n", 2);
        } else {
            if (is_favs[i]) write(fd, "t\n", 2);
            else write(fd, "f\n", 2);
        }

        i = i + 1;
    }

    if (!is_fav) {
        write(fd, s.path, strLen(s.path));
        write(fd, ",", 1);

        if (s.fav) write(fd, "t\n", 2);
        else write(fd, "f\n", 2);
    }

    close(fd);
}


int read_filer(int fd){
    int bytes_read;
    char[] buffer = "             ";
    char[] line;
    int line_pos = 0;
    int j = 0;
    if(fd >= 0){
        bytes_read = read(fd, buffer, 1024);
        int buf_pos = 0;
        while (buf_pos < bytes_read) {
            if (buffer[buf_pos] == '\n' || buffer[buf_pos] == '\r') {
                line[line_pos] = '\0'; // 行終端
                j = j + 1;
                line_pos = 0;
            } else {
                line[line_pos] = buffer[buf_pos];
                line_pos = line_pos + 1;
            }
            buf_pos = buf_pos + 1;
        }
    }
    return j;
}


public album[] fetch_albums() {
    char[] filepath;
    int fd = 0;
    int bytes_read;
    for(int i = 0; i<5; i=i+1){
        filepath = pltCat(album_name[i]);
        fd = open(filepath,0);
        bytes_read = read_filer(fd);
        al[i].name = album_name[i];
        al[i].song_num = bytes_read;
    }
    return al;
}

public playlist[] fetch_playlist() {
    char[] filepath;
    int fd = 0;
    int bytes_read;
    for(int i = 0; i<5; i=i+1){
        filepath = pltCatPl(playlist_name[i]);
        fd = open(filepath,0);
        bytes_read = read_filer(fd);
        pl[i].name = playlist_name[i];
        pl[i].song_num = bytes_read;
    }
    return pl;
}


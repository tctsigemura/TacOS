char[][] word_box = {"          ","          ","          ","          ","          ","          ","          ","          ","          ","          "};
char[][] sort_word_box = {"          ","          ","          ","          ","          ","          ","          ","          ","          ","          "};

public song[] fetch_songs(char[] name, char[] sort) {//nameはアルバム名，プレイリスト名で  pl1とかal2
    for(int k=0;k<10;k=k+1){
        strCpy(word_box[k], "          ");
        strCpy(sort_word_box[k], "          ");
    }
    int fd;
    int read_box;
    for(int i=0; i<5; i=i+1 ){
        create_album(album_name[i]);
    }
    
    char[] Al_filepath;
    char[] Pl_filepath;
    char[] buffer = "                                                           ";
    char[] line;
    int bytes_read;
    int line_pos = 0;
    
    char[] str = "                    ";
    Al_filepath = pltCat(name); //     Album/~~.txt
    Pl_filepath = pltCatPl(name); //   Playlist/~~.txt　　ディレクトリ指定することができ増田．テキストを読み込んでいく←読み込む能力がないのでパス
    dbgPutStr(Al_filepath);
    dbgPutStr("\n");
    dbgPutStr(Pl_filepath);
    dbgPutStr("\n");


    
    
    ////////////////プレイリスト////////////////
    fd = open(Pl_filepath,0);
    for(int j = 0;j<sizeof(song);j=j+1){
        sort_songs[j].artist = "          "; 
        sort_songs[j].path = "          ";
        sort_songs[j].name = "          ";
    }
    if(fd >= 0){
        int i = 0;
        bytes_read = read(fd, buffer, 1024);
            int buf_pos = 0;
            while (buf_pos < bytes_read) {
                if (buffer[buf_pos] == '\n' || buffer[buf_pos] == '\r') {
                    line[line_pos] = '\0'; // 行終端
                    dbgPutStr(line); // 1行出力
                    dbgPutStr("\n");
                    strCpy(word_box[i], line);
                    i = i + 1;
                    line_pos = 0;
                } else {
                    line[line_pos] = buffer[buf_pos];
                    line_pos = line_pos + 1;
                }
                buf_pos = buf_pos + 1;
            }
        if (line_pos > 0) {
            line[line_pos] = '\0';
            dbgPutStr(line);
            dbgPutStr("\n");
        }

    }else{
        dbgPutStr("not pl\n");
    }
    close(fd);
    ////////////////アルバーむ
    fd = open(Al_filepath,0);
    if(fd >= 0){
        int i = 0;
            int buf_pos = 0;
            while (buf_pos < bytes_read) {
                if (buffer[buf_pos] == '\n' || buffer[buf_pos] == '\r') {
                    line[line_pos] = '\0'; // 行終端
                    dbgPutStr(line); // 1行出力
                    dbgPutStr("\n");
                    strCpy(word_box[i], line);
                    i = i + 1;
                    line_pos = 0;
                } else {
                    line[line_pos] = buffer[buf_pos];
                    line_pos = line_pos + 1;
                }
                buf_pos = buf_pos + 1;
            }

        if (line_pos > 0) {
            line[line_pos] = '\0';
            dbgPutStr(line);
            dbgPutStr("\n");
        }
        
    }else{
        dbgPutStr("not al\n");
    }

    close(fd);
    
    //　追加じゅん　名前順　アルバムじゅん
    int num = sizeof(song) ;
    // putDec(num,1);
    if(strCmp(sort, "music_name") == 0){         // アスキーコードで比較 
        for (int i = 0; i < num; i = i+1){
            for(int k = 0; k < num; k= k+1){
                if(strCmp(songs[i].path,sort_word_box[k]) == 0){
                    if(strCmp(songs[i].path,"          ") !=0 ){
                    dbgPutStr("cmp ");
                    tmp_song = songs[i];
                    songs[i] = songs[k];
                    songs[k] = tmp_song;
                    sort_songs[i] = songs[k];
                    songs[k] = tmp_song;
                    }
                }
            }
        }
    }else if(sort == "day"){ //そのまま出力
        return songs;

    }else if(sort == "all"){
        return songs;
    }

    return sort_songs;

}


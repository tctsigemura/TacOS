//
// --- 構造体 ---
//
struct album {
    int song_num;
    char[] name;
};

struct song {
    int index;
    char[] name;
    Bool fav;
    char[] artist;
    char[] path;     
};

struct playlist {
    int song_num;
    char[] name;
};

struct SelectedItem {
    char[] type;
    void[] item; 
};

struct I_ScrnSt {  
    int mode;
    int sw;
    char[][] scrndata;
    int volume;
};

struct O_ScrnSt {  
    char[] type;
    void[] item;
};

struct I_StrmSt { 
    int sw; 
};

struct O_StrmSt {
    song crt_song;
    song[] history;
    int type;
    char[] super_name;
};

struct I_LibSt {
    char[] type;
    char[] name;
    char[] sort;
};

struct O_LibSt {
    char[] type;
    void[] item;
};

struct I_StgSt {
    int sw;
};

struct I_PlistSt {
    char[] pltname;
    song[] songs;
};

struct O_PlistSt {
    playlist plt;
};


//
// --- 関数 ---
//
void main();
int get_sw();
O_ScrnST act_screen(I_ScrnSt input);
O_StrmSt act_stream(I_StrmSt input);
O_LibSt act_libracy(I_LibSt input);
O_PlistSt act_playlist(I_PlistSt input);
void act_settings(I_StgsSt input);
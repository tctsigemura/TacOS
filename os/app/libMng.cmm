char[][] sortWords(char[][] words, int n) {
    // for(int j = 0 ; j < 10; j = j+1 ) {
    //     dbgPutStr(words[j]);
    //     dbgPutStr("\n");
    // }
    for (int i = 0; i < n-1; i = i+1) {
        if (strLen(words[i]) == 0 || words[i][0] == ' ') continue;
        for (int j = i+1; j < n; j = j+1) {
            if (strLen(words[j]) == 0 || words[j][0] == ' ') continue;
            if (strCmp(words[i], words[j]) > 0) {
                char[] tmp = "          ";
                strCpy(tmp, words[i]);
                strCpy(words[i], words[j]);
                strCpy(words[j], tmp);
            }
        }
    }
    // dbgPutStr("sort word\n");
    // for(int j = 0 ; j < 10; j = j+1 ) {
    //     dbgPutStr(words[j]);
    //     dbgPutStr("\n");
    // }
    return words;
}



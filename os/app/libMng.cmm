public album[] fetch_albums() {
    char[] filepath;
    int fd = 0;
    int bytes_read;
    for(int i = 0; i<5; i=i+1){
        filepath = pltCat(album_name[i]);
        fd = open(filepath,0);
        bytes_read = read_filer(fd);
        al[i].name = album_name[i];
        al[i].song_num = bytes_read;
    }
    return al;
}

public playlist[] fetch_playlist() {
    char[] filepath;
    int fd = 0;
    int bytes_read;
    for(int i = 0; i<5; i=i+1){
        filepath = pltCatPl(playlist_name[i]);
        fd = open(filepath,0);
        bytes_read = read_filer(fd);
        pl[i].name = playlist_name[i];
        pl[i].song_num = bytes_read;
    }
    return pl;
}

char[][] art = {"          ","          ","          ","          ","          ","          ","          ","          ","          ","          "};
// char[][] art ;

public char[][] fetch_artists() {
    int unique_artist_count = 0;
    for(int i = 0; i<sizeof(song); i = i+1){
        boolean is_already_found = false;
        for(int j=0; j<10; j = j+1){
            if(strCmp(songs[i].artist,art[j]) == 0){
                is_already_found = true;            
                break;
            }
        }
        if(!is_already_found){
            art[unique_artist_count] = songs[i].artist;
            unique_artist_count = unique_artist_count + 1;
        }
    }        
    return art;
}
char[][] fav_box;
public void fav_song(song[] songs, boolean is_favorite, int for_index){
    char[] filepath = "/fav.txt";
    int fd;
    // remove(filepath);
    fd = open(filepath, 2);
    if(fd < 0) {
        creat(filepath);
        dbgPutStr("not found file\n");
        fd = open(filepath, O_APPEND);
    }
    // fav_box = read_favlist(fd);
    // close(fd);
    // fd = open(filepath, 1);
    // for(int j = 0 ; j < 10 ; j = j + 1){
    //     dbgPutStr(favlist[0]);
    //     dbgPutStr("\n");
    // }
    for(int i = 0 ; i < for_index ; i = i + 1){
        if(strCmp(songs[i].path,"          ") != 0){//テキストファイルから取得するファイルパス
            write(fd, songs[i].path, strLen(songs[i].path));
        
            if (is_favorite) {
                write(fd, ",true\n", 6);
            } else {
                write(fd, ",false\n", 7);
            }
        }
    }
    
    close(fd);
}
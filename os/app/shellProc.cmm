public void disp_chii(int x, int y) {
  
  for (int row = 0; row < 7; row=row + 1) {  // 2行分ループ
    for (int col = 0; col < 6; col= col + 1) {  // 6列分ループ
      int index = row * 6 + col;  // 現在のマスのインデックス（0〜41）
      locateXY(x + col + 5, y + row);  // 座標に描画（x:列方向, y:行方向）
      spiWriteLcdDat(chii_font_list[index], 8);  // 1マス = 8バイト
    }
  }
}


void initialScreen() {
  cls();
  // 列行
  locateXY(0, 0);
  putStr("     Welcome");
  disp_chii(0, 1);  // (0,3) から 6×7 マスのビットパターンを描画
}

song[] openingsong = {
    {"song", 0, "pajama", false, "pajama", "/Pajama.mp3"},
    {"song", -1, "", false, "", ""}
};

public void shellMain() {
    spiResetLcd();                                    // sleepを使用するので
    spiResetMp3();                                    //   プロセスが実行する

    // mp3Proc init
    initPlaylist();

sleep(200);
  play(openingsong, 0);  
  while(true){
    int sw = readSw();
    int num = swToNum(sw);
    initialScreen();
    if(num == 1||num == 2||num == 3||num == 4||num == 5||num == 6){
      cls();
      stop(true);
      break;
    }
    sleep(10);
  }

    // 初回起動時はホーム画面
    goHomeScreen();


    for (;;) {
        int sw = readSw();
        int num = swToNum(sw);

        // --- 強制メニューモード移動 ---
        if (num == 1) {
            mode = MENU;
            goHomeScreen();

            check_item(-1);
            init_selectingItems();

            is_power = false;
        }

 // --- モードごとに処理を分ける ---
        // メニューモード
        if (mode == MENU) {
            if (num == 2) {
                up_cursor();
            }
            else if (num == 4) {
                down_cursor();
            }
            else if (num == 6) {
                SelectedItem s = select();

                void[] tmp = s.item;
                modeSt tmpmode = tmp;

                if (tmpmode.id == STREAMING) {
                    mode = STREAMING;

                    info.playingsong = get_playingsong();
                    info.idx = get_idx();
                    info.is_normal = get_is_normal();
                    info.is_loop = get_is_loop();
                    info.is_repeat = get_is_repeat();
                    info.is_shuffle = get_is_shuffle();
                    info.playstatus = get_playstatus();
                    info.totalsongs = get_totalsongs();
                    info.is_paused = get_ispaused();

                    streamScreen(info);
                }
                else if (tmpmode.id == SONGS) {
                    mode = SONGS;
                    goSelectScreen();
                }
                else if (tmpmode.id == PLAYLISTS) {
                    mode = PLAYLISTS;

                    goPlaylistSettingsScreen();
                }
                else if (tmpmode.id == SETTINGS) {
                    mode = SETTINGS;

                    goSettingsScreen();
                }
            }
        }
        // 再生モード
        else if (mode == STREAMING) {
            if (num == 3) {
                if (get_is_normal()) loop();
                else if (get_is_loop()) repeat();
                else if (get_is_repeat()) shuffle();
                else if (get_is_shuffle()) normal();

                info.is_normal = get_is_normal();
                info.is_loop = get_is_loop();
                info.is_repeat = get_is_repeat();
                info.is_shuffle = get_is_shuffle();

                streamScreen(info); 
            }
            else if (num == 4) {
                previous();
                
                info.idx = get_idx();
                info.playingsong = get_playingsong();
                streamScreen(info);
            }
            else if (num == 5) {
                if (get_playstatus() == 1) {
                    if (get_ispaused()) mp3resume();
                    else mp3pause();
                }

                info.playstatus = get_playstatus();
                info.is_paused = get_ispaused();
                streamScreen(info);
            }
            else if (num == 6) {
                next();

                info.idx = get_idx();
                info.playingsong = get_playingsong();
                streamScreen(info);
            }
        }
        // 選曲モード 
        else if (mode == SONGS) {
            // 本当はここでファイルとディレクトリを読み出してくる
            if (num == 1) {}
            else if (num == 2) {
                up_cursor();
            }
            else if (num == 3) {
                back();
            }
            else if (num == 4) {
                down_cursor();
            }
            else if (num == 5) {
                // attach fav. attr
                SelectedItem s = select();

                song tmpsong = s.item;
                tmpsong.fav = !tmpsong.fav;
                printF("faved %s\n", tmpsong.path);

                fav_song(tmpsong);
                display_screen();
            }
            else if (num == 6) {
                SelectedItem s = select();

                void[] tmp = s.item;
                typeSt tmptype = tmp;

                if (strCmp(tmptype.type, "album") == 0) {
                    album tmpalbum = tmp;

                    // アルバムから曲をとる
                    queue = goSongsScreen(tmpalbum.name, null);
                }
                else if (strCmp(tmptype.type, "playlist") == 0) {
                    playlist tmpplaylist = tmp;

                    // プレイリストから曲をとる
                    queue = goSongsScreen(tmpplaylist.name, null);
                }
                else if (strCmp(tmptype.type, "song") == 0) {
                    song tmpsong = tmp;

                    // 曲を流す
                    play(queue, tmpsong.index);
                }
            }
        }
        // プレイリストモード
        else if (mode == PLAYLISTS) {
            if (num == 2) {
                up_cursor();
            }
            else if (num == 4) {
                down_cursor();
            }
            else if (num == 6) {
                SelectedItem s = select();

                void[] tmp = s.item;
                modeSt tmpmode = tmp;

                if (strCmp(tmpmode.name, "Make Playlist") == 0) {
                    mode = MAKE;

                    goMakeScreen();
                }
                else if (strCmp(tmpmode.name, "Delete Playlist") == 0) {
                    mode = DELETE;

                    goDeleteScreen();
                }
                else if (strCmp(tmpmode.name, "Add Songs") == 0) {
                    mode = ADD;

                    goAddScreen();
                }
                else if (strCmp(tmpmode.name, "Remove Songs") == 0) {
                    mode = REMOVE;

                    goRemoveScreen();
                }
            }
        }
        // プレイリスト作成モード
        else if (mode == MAKE) {
            if (num == 2) {
                up_cursor();
            }
            else if (num == 3) {
                int page = get_page();

                if (page == 1) {
                    check_item(-1);
                    init_selectingItems();

                    mode = PLAYLISTS;
                }

                back();
            }
            else if (num == 4) {
                down_cursor();
            }
            else if (num == 5) {
                if (selecting_num != 0) {
                    for (int i=0;i<10;i=i+1) dbgPutStr(playlistSongs[i].name);
                    create_playlist(playlistSongs);
                }
            }
            else if (num == 6) {
                SelectedItem s = select();

                void[] tmp = s.item;
                typeSt tmptype = tmp;

                selected_when_create_and_add(s);
            }
        }
        else if (mode == DELETE) {
            if (num == 2) {
                up_cursor();
            }
            else if (num == 3) {
                mode = PLAYLISTS;

                goPlaylistSettingsScreen();
            }
            else if (num == 4) {
                down_cursor();
            } else if (num == 6) {
                SelectedItem s = select();
                typeSt tmptype = s.item;

                if (strCmp(tmptype.type, "playlist") == 0) {

                    playlist tmpplaylist = s.item;

                    delete_playlist(tmpplaylist.name);

                    mode = PLAYLISTS;
                    goPlaylistSettingsScreen();
                }
            }
        }
        // --- プレイリストに曲を追加する ---
        else if (mode == ADD) {
            if (num == 2) {
                up_cursor();
            }
            else if (num == 3) {
                int page = get_page();

                if (page == 1) {
                    check_item(-1);
                    init_selectingItems();

                    mode = PLAYLISTS;
                }

                back();
            }
            else if (num == 4) {
                down_cursor();
            }
            else if (num == 5) {
                playlist[] playlists = fetch_playlists();

                resetScreen();

                int i = 0;
                while (i < 5 && playlists[i].num != -1) {
                    screen[i] = playlists[i];
                    i = i + 1;
                }

                display_items(screen, "Select Display", "straight");
            }
            else if (num == 6) {
                SelectedItem s = select();

                void[] tmp = s.item;
                typeSt tmptype = tmp;

                selected_when_create_and_add(s);

                if (strCmp(tmptype.type, "playlist") == 0) {
                    if (selecting_num != 0) {
                        playlist tmpplaylist = tmp;
                        add_songs(tmpplaylist.name, playlistSongs);

                        mode = PLAYLISTS;
                        goPlaylistSettingsScreen();

                        init_selectingItems();
                    }
                }
            }
        }
        // --- プレイリストから曲を削除する ---
        else if (mode == REMOVE) {
            if (num == 2) {
                up_cursor();
            }
            else if (num == 3) {
                int page = get_page();

                if (page == 1) {
                    check_item(-1);
                    init_selectingItems();

                    mode = PLAYLISTS;
                }

                back();
            }
            else if (num == 4) {
                down_cursor();
            }
            else if (num == 5) {
                // 選択されている曲数が1曲以上
                // selectingItems[i]のnameのアルバム曲一覧を取ってきて、
                // is_selecting[j]がtrueのsongs[j]を溜め込んで
                // そのままcreate-playlistで書き込む
                //
                if (selecting_num != 0) {
                    printF("playlist name: %s\n", now_dir);
                    printF("remove songs:\n");

                    for (int i=0; i<10; i=i+1) printF("    %s\n",playlistSongs[i].name);
                    remove_songs(now_dir, playlistSongs);

                    mode = PLAYLISTS;
                    goPlaylistSettingsScreen();
                }
            }
            else if (num == 6) {
                SelectedItem s = select();

                void[] tmp = s.item;
                typeSt tmptype = tmp;

                if (strCmp(tmptype.type, "playlist") == 0) {
                    // 初期化
                    init_selectingItems();
                    resetScreen();
                    check_item(-1);
                    
                    playlist tmpplaylist = tmp;

                    goSongsScreen(tmpplaylist.name, null);

                    strCpy(now_dir, tmpplaylist.name);
                    
                }
                else if (strCmp(tmptype.type, "song") == 0) {
                    boolean is_check = check_item(s.idx);
                    song tmpsong = tmp;

                    if (is_check) {
                        if (selecting_num == 10) {
                            check_item(s.idx);
                        }
                        else {
                            for (int i=0; i<10; i=i+1) {
                                if (strCmp(playlistSongs[i].path, "") == 0) {
                                    strCpy(playlistSongs[i].path, tmpsong.path);
                                    playlistSongs[i].index = 0;
                                    break;
                                }
                            }

                            selecting_num = selecting_num + 1;

                            for (int i=0; i<10; i=i+1) {
                                if (strCmp(selectingItems[i].name, now_dir) == 0) {
                                    selectingItems[i].is_selecting[s.idx] = true;
                                }
                            }
                        }
                    }
                    else {
                        for (int i=0; i<10; i=i+1) {
                            if (strCmp(playlistSongs[i].path, tmpsong.path) == 0) {
                                strCpy(playlistSongs[i].path, "");
                                playlistSongs[i].index = -1;
                                break;
                            }
                        }

                        selecting_num = selecting_num - 1;

                        for (int i=0; i<10; i=i+1) {
                            if (strCmp(selectingItems[i].name, now_dir) == 0) {
                                selectingItems[i].is_selecting[s.idx] = false;
                            }
                        }
                    }
                }
            }
            if (num == 3) {
                mode = PLAYLISTS;

                goPlaylistSettingsScreen();
            }
        }
        // 設定モード
        else if (mode == SETTINGS) {
            if (num == 2) {
                up_cursor();
                if (is_power) powerScreen(0);
            }
            else if (num == 3) {
                back();
                is_power = false;
            }
            else if (num == 4) {
                down_cursor();
                if (is_power) powerScreen(1);
            }
            // 音量設定・電源切
            else if (num == 6) {
                SelectedItem s = select();

                void[] tmp = s.item;
                modeSt tmpmode = tmp;

                if (strCmp(tmpmode.name, "volume") == 0) {
                    mode = VOLUME;

                    int vol = get_volume();

                    volumeScreen(vol);
                }
                else if (strCmp(tmpmode.name, "power off") == 0) {
                    goChoiseScreen("Turn Power Off?");

                    is_power = true;

                    powerScreen(0);
                }
                // type: power選択時の挙動
                else if (strCmp(tmpmode.name, "YES") == 0) {
                    // --- ending movie ---
                    clear();

                    poweroffScreen();

                    sleep(1000);

                    clear();
                    power_off();
                }
                else if (strCmp(tmpmode.name, "NO") == 0) {
                    back();
                }
            }
        }
        else if (mode == VOLUME) {
            if (num == 3) {
                // instead of back();
                mode = SETTINGS;
                goSettingsScreen();
            }
            else if (num == 4) { 
                down_volume();

                int vol = get_volume();
                volumeScreen(vol);
            }
            else if (num == 6) {
                up_volume();

                int vol = get_volume();
                volumeScreen(vol);
            }
        }

        /*
         * 曲がひとりでに終わった時の処理
         */
        //   [Warning]
        //   この別プロセス内で呼ばなければ、stop(), play()で
        //   フリーズして止まってしまうためここで呼ぶ
        if (get_playstatus() == -1 && !get_wasStoppedByUser()) {
            onSongEnd();
        }

        sleep(10);  // 10ms に一度
    }
}


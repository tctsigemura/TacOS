// スクリーンをリセットする
void resetScreen() {
    for (int i=0; i<50; i=i+1) {
        screen[i] = null;
    }
}

// selecting itemsをリセットする
void init_selectingItems() {
    for (int i=0; i<10; i=i+1) {
        strCpy(playlistSongs[i].path, "");
        playlistSongs[i].index = -1;
        selectingItems[i].is_selecting = is_selectings[i];
        strCpy(selectingItems[i].name, "");
        
        for (int j=0; j<10; j=j+1)
            selectingItems[i].is_selecting[j] = false;
    }

    selecting_num = 0;
    strCpy(now_dir, "");
}

// ------ 関数群 ------
// Homeスクリーンを描画
void goHomeScreen() {
    // スクリーンのリセット
    resetScreen();

    // スクリーンにモードをセット
    int i = 0;
    while (modes[i] != null) {
        screen[i] = modes[i];

        i = i + 1;
    }

    // スクリーンに描画
    display_items(screen, "Menu", "mode");
}

playlist favPL = {"playlist", 0, "fav"};
// 選曲スクリーンを描画
void goSelectScreen() {
    // スクリーンのリセット
    resetScreen();

    // ここでヒストリーとかの情報を取得できるようにしたいよね
    playlist[] playlists = fetch_playlists();
    album[] albums = fetch_albums();

    // スクリーンにプレイリストをセット
    int i = 0;
    while (i < 5 && playlists[i].num != -1) {
        screen[i] = playlists[i];

        i = i + 1;
    }

    screen[i] = favPL;

    i = i + 1;


    int j = 0;
    // スクリーンにアルバムをセット
    while (j < 5 && albums[j].num != -1) {
        screen[i] = albums[j];

        i = i + 1;
        j = j + 1;
    }
    
    display_items(screen, "Select Songs", "mode");
}

// 選曲スクリーンを描画
song[] goSongsScreen(char[] name, char[] sort) {
    // スクリーンのリセット
    resetScreen();

    // 曲をとってくる
    song[] songs = fetch_songs(name, sort);

    // スクリーンに曲をセット
    int i = 0;
    while (songs[i].index != -1) {
        screen[i] = songs[i];

        i = i + 1;
    }

    // スクリーンに描画
    display_items(screen, "Select Songs", "straight");

    return songs;
}


//-----------------------------------------------------------------------------
// MP3 プレーヤのメインプロセス
//-----------------------------------------------------------------------------
// select()によってリターンされたオブジェクトの型を判定するためのmeta変数

// 現在のモード
int mode = 0;
boolean is_power = false;

void selected_when_create_and_add(SelectedItem s) {
    void[] tmp= s.item;
    typeSt tmptype = tmp;

    if (strCmp(tmptype.type, "album") == 0) {
        // 初期化
        resetScreen();
        check_item(-1);
        
        album tmpalbum = tmp;

        goSongsScreen(tmpalbum.name, null);

        strCpy(now_dir, tmpalbum.name);
        
        // もしもともとseleting itemsに保存されていれば、checkをつける
        for (int i=0; i<10; i=i+1) {
            if (strCmp(selectingItems[i].name, tmpalbum.name) == 0) {
                for (int j=0; j<10; j=j+1) {
                    if (selectingItems[i].is_selecting[j])
                        check_item(j);
                }
                break;
            }
            else if(strCmp(selectingItems[i].name, "") == 0) {
                strCpy(selectingItems[i].name, now_dir);
                break;
            }
        }
    }
    else if (strCmp(tmptype.type, "song") == 0) {
        boolean is_check = check_item(s.idx);
        song tmpsong = tmp;

        if (is_check) {
            if (selecting_num == 10) {
                check_item(s.idx);
            }
            else {
                for (int i=0; i<10; i=i+1) {
                    if (strCmp(playlistSongs[i].path, "") == 0) {
                        strCpy(playlistSongs[i].path, tmpsong.path);
                        playlistSongs[i].index = 0;
                        break;
                    }
                }

                selecting_num = selecting_num + 1;

                for (int i=0; i<10; i=i+1) {
                    if (strCmp(selectingItems[i].name, now_dir) == 0) {
                        selectingItems[i].is_selecting[s.idx] = true;
                    }
                }
            }
        }
        else {
            for (int i=0; i<10; i=i+1) {
                if (strCmp(playlistSongs[i].path, tmpsong.path) == 0) {
                    strCpy(playlistSongs[i].path, "");
                    playlistSongs[i].index = -1;
                    break;
                }
            }

            selecting_num = selecting_num - 1;

            for (int i=0; i<10; i=i+1) {
                if (strCmp(selectingItems[i].name, now_dir) == 0) {
                    selectingItems[i].is_selecting[s.idx] = false;
                }
            }
        }
    }
}


